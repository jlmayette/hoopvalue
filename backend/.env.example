# --- Database (Neon, Supabase, or local Postgres) ---
DATABASE_URL=postgresql://user:password@host:5432/hoopvalue

# --- Cache (Upstash Redis) ---
# Get these from https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# --- Server ---
PORT=3001
NODE_ENV=development

# --- CORS ---
# Comma-separated list of allowed origins for the frontend
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Scraper schedule (cron strings, defaults shown) ---
SCRAPE_RANKINGS_CRON="0 4 * * 1"
# Mondays at 04:00 UTC

# --- Optional: a simple admin token to trigger manual refreshes ---
ADMIN_TOKEN=change-this-to-something-random
